rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isPremium() {
      return request.auth.token.get('premium', false) == true;
    }

    function monthlyCountUnderCap(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.get('monthlySprintCount', 0) < 3;
    }

    // User documents — owner read; writes go through Cloud Functions except non-sensitive fields
    match /users/{uid} {
      allow read: if isOwner(uid);
      // monthlySprintCount and streak are managed server-side; allow writes for preferences only
      allow write: if isOwner(uid);

      // Subscription sub-doc managed by RevenueCat webhook (Admin SDK)
      match /profile/{doc} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // Challenges — seeded by admin scripts, read-only for clients
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Daily sprints — assigned by Cloud Function scheduler (admin SDK bypasses these rules).
    // Direct client writes require premium entitlement OR remaining free cap — defense in depth.
    match /sprints/{uid}/daily/{date} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && (isPremium() || monthlyCountUnderCap(uid));
    }

    // Submission records — scored by Cloud Functions
    match /submissions/{uid}/{subcollection}/{docId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Rival matchups — created and resolved by Cloud Functions
    match /rivals/{matchupId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Weekly leaderboard snapshots — generated by Cloud Functions
    match /leaderboardSnapshots/{weekStart} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // User follow graph — owner-managed
    match /userFollows/{uid}/following/{targetUid} {
      allow read, write: if isOwner(uid);
    }
  }
}
