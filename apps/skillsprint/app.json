{
  "expo": {
    "name": "SkillSprint",
    "slug": "skillsprint",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F13"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lemaa.skillsprint",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F13"
      },
      "package": "com.lemaa.skillsprint",
      "permissions": ["INTERNET"]
    },
    "plugins": ["expo-apple-authentication"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
