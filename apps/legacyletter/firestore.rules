rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Legacies subcollection
      match /legacies/{legacyId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // Validate on create/update
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.keys().hasAll(['type', 'title', 'status', 'createdAt'])
          && request.resource.data.type in ['text', 'voice', 'video']
          && request.resource.data.status in ['draft', 'scheduled', 'delivered']
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120;

        allow update: if request.auth != null
          && request.auth.uid == uid
          // Prevent clients from marking their own legacies as delivered
          && !(request.resource.data.status == 'delivered'
               && resource.data.status != 'delivered');
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
