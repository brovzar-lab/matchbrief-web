# Firebase — copy to .env.local and fill in real values
EXPO_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_VALUE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_VALUE
EXPO_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_WITH_VALUE
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_VALUE
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_VALUE
EXPO_PUBLIC_FIREBASE_APP_ID=REPLACE_WITH_VALUE

# Use local Firebase Emulators during development
EXPO_PUBLIC_USE_EMULATORS=true

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=REPLACE_WITH_VALUE
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=REPLACE_WITH_VALUE

# Cloud Functions (set in Firebase env config, not here)
# SENDGRID_API_KEY=REPLACE_WITH_VALUE
