{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "glowlog",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "lib"]
    }
  ],
  "emulators": {
    "auth": {
      "port": 9200
    },
    "functions": {
      "port": 5202
    },
    "firestore": {
      "port": 8181
    },
    "ui": {
      "enabled": true
    }
  }
}
