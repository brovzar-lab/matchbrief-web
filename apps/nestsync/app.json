{
  "expo": {
    "name": "NestSync",
    "slug": "nestsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lemaa.nestsync",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1628"
      },
      "package": "com.lemaa.nestsync",
      "permissions": ["INTERNET"]
    },
    "plugins": [],
    "experiments": {
      "typedRoutes": false
    }
  }
}
