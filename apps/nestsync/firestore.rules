rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Household rules: only the two parents may access their household
    match /households/{householdId} {
      function isHouseholdMember() {
        return request.auth != null && (
          resource.data.parent1Uid == request.auth.uid ||
          resource.data.parent2Uid == request.auth.uid
        );
      }

      function isParent1Creating() {
        return request.auth != null &&
          request.resource.data.parent1Uid == request.auth.uid;
      }

      allow create: if request.auth != null && isParent1Creating();
      allow read, update: if isHouseholdMember();
      allow delete: if false;

      // Events subcollection
      match /events/{eventId} {
        allow read, write: if isHouseholdMember();
      }

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isHouseholdMember();
        // Only allow write if senderId matches auth uid (prevents spoofing)
        allow create: if isHouseholdMember() &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isHouseholdMember();
        allow delete: if false;
      }

      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read: if isHouseholdMember();
        allow create: if isHouseholdMember() &&
          request.resource.data.paidBy == request.auth.uid;
        allow update: if isHouseholdMember();
        allow delete: if false;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
