rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Deny all by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Users can only read/write their own audio files
    match /users/{uid}/audio/{filename} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid
        && filename.matches('.*\\.m4a')
        && request.resource.size <= 5 * 1024 * 1024; // 5 MB cap
    }
  }
}
