{
  "expo": {
    "name": "DriftJournal",
    "slug": "driftjournal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f3ff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lemaa.driftjournal"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f3ff"
      },
      "package": "com.lemaa.driftjournal"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "experiments": {
      "typedRoutes": false
    }
  }
}
