rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Household invites: any authenticated user can read (to join), only members can write
    match /household_invites/{inviteCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/households/$(resource.data.householdId)) &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.memberIds;
    }

    // Households and all subcollections: only members can read/write
    match /households/{householdId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.memberIds;

      // Allow create: the creator adds themselves
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberIds;

      match /members/{userId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
      }

      match /incomes/{incomeId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
      }

      match /expenses/{expenseId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
      }

      match /goals/{goalId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
      }

      match /goal_contributions/{contributionId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
      }
    }
  }
}
