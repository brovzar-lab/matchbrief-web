rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // User profiles — readable/writable only by the owner
    // -----------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------------
    // Company + location scoping
    // Workers can only access their own location (enforced via custom claims).
    // Managers can access everything within their company.
    // -----------------------------------------------------------------------
    match /companies/{companyId} {
      function isInCompany() {
        return request.auth != null &&
          request.auth.token.companyId == companyId;
      }

      function isManagerInCompany() {
        return isInCompany() &&
          request.auth.token.role == 'manager';
      }

      function isInLocation(locationId) {
        return isInCompany() && (
          request.auth.token.role == 'manager' ||
          request.auth.token.locationId == locationId
        );
      }

      allow read: if isInCompany();
      allow write: if isManagerInCompany();

      match /locations/{locationId} {
        allow read: if isInLocation(locationId);
        allow write: if isManagerInCompany();

        match /workers/{workerId} {
          // Workers can update their own fcmToken; managers can write anything
          allow read:   if isInLocation(locationId);
          allow create: if isManagerInCompany();
          allow update: if isManagerInCompany() ||
            (isInLocation(locationId) && request.auth.uid == workerId &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']));
          allow delete: if isManagerInCompany();
        }

        match /shifts/{shiftId} {
          allow read:   if isInLocation(locationId);
          allow write:  if isManagerInCompany();
        }

        match /swapRequests/{requestId} {
          allow read: if isInLocation(locationId);

          // Workers can create open swap requests for their own shifts
          allow create: if isInLocation(locationId) &&
            request.resource.data.status == 'open' &&
            request.resource.data.requesterId == request.auth.uid &&
            request.resource.data.claimantId == null;

          // Workers can claim an open request (must not be their own)
          allow update: if isInLocation(locationId) &&
            resource.data.status == 'open' &&
            request.resource.data.status == 'claimed' &&
            request.resource.data.claimantId == request.auth.uid &&
            resource.data.requesterId != request.auth.uid;

          // Managers can approve or deny claimed requests
          allow update: if isManagerInCompany() &&
            resource.data.status in ['claimed'] &&
            request.resource.data.status in ['approved', 'denied'];

          allow delete: if false;
        }
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
